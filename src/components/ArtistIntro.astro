---
import { Image } from 'astro:assets';
import artistPhoto from '../assets/artist-photo-2.jpg';
---

<section class="intro">
  <div class="intro__inner container">
    <div class="intro__photo-col">
      <div class="intro__photo-frame">
        <Image
          src={artistPhoto}
          alt="The artist"
          width={320}
          class="intro__photo"
        />
      </div>
      <div class="intro__media-pills">
        <span class="intro__pill">Watercolor</span>
        <span class="intro__pill">Colored Pencil</span>
        <span class="intro__pill">Ceramics</span>
        <span class="intro__pill">Photography</span>
      </div>
    </div>

    <div class="intro__text">
      <span class="intro__label">About me</span>
      <h2 class="intro__heading">
        I create with my hands<br/><em>and let the materials lead</em>
      </h2>
      <p class="intro__body">
        From detailed colored pencil portraits to hand-built ceramic mugs,
        my work lives in the space where patience meets play. I'm drawn to
        fantasy, nature, and the small details that make something feel alive.
      </p>
      <a href="/about" class="intro__link">
        More about me &rarr;
      </a>
    </div>
  </div>
</section>

<style>
  .intro {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--divider);
  }

  .intro__inner {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: var(--space-xl);
    max-width: 900px;
  }

  .intro__photo-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .intro__photo-frame {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--divider);
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
  }

  .intro__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .intro__media-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    max-width: 200px;
  }

  .intro__pill {
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    padding: 4px 10px;
    border-radius: 2rem;
    border: 1px solid var(--divider);
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .intro__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .intro__label {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .intro__heading {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 400;
    line-height: 1.4;
    color: var(--text-primary);
  }

  .intro__heading em {
    color: var(--accent);
    font-style: italic;
  }

  .intro__body {
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 550px;
    margin-top: var(--space-xs);
  }

  .intro__link {
    display: inline-block;
    margin-top: var(--space-md);
    font-family: var(--font-heading);
    font-size: 1rem;
    font-style: italic;
    color: var(--text-secondary);
    transition: color var(--transition);
  }

  .intro__link:hover {
    color: var(--accent);
  }

  @media (max-width: 600px) {
    .intro__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .intro__photo-col {
      order: -1;
    }

    .intro__photo-frame {
      width: 140px;
      height: 140px;
    }

    .intro__text {
      align-items: center;
    }
  }
</style>
