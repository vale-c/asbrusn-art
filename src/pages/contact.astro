---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact">
  <section class="contact container">
    <h1 class="contact__heading">Get in Touch</h1>
    <p class="contact__intro">
      Interested in commissions or collaborations? Feel free to reach out.
    </p>

    <div class="contact__grid">
      <a href="mailto:gege95.tuz@hotmail.it" class="contact__card">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
        <span class="contact__label">Email</span>
        <span class="contact__value">gege95.tuz@hotmail.it</span>
      </a>

      <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="contact__card">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" />
          <circle cx="12" cy="12" r="5" />
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
        </svg>
        <span class="contact__label">Instagram</span>
        <span class="contact__value">@asbrusn.art</span>
      </a>
    </div>

    <div class="contact__commissions">
      <h2 class="contact__subheading">Commissions</h2>
      <p>
        I'm currently <strong>open</strong> for commissions.
        Send me a message describing what you have in mind, and I'll get back to you
        with availability and pricing.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
    max-width: 700px;
  }

  .contact__heading {
    font-size: clamp(2rem, 5vw, 3rem);
    text-align: center;
    margin-bottom: var(--space-md);
    font-weight: 400;
    letter-spacing: 0.08em;
  }

  .contact__intro {
    text-align: center;
    color: var(--text-secondary);
    margin-bottom: var(--space-xl);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .contact__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: var(--surface);
    border-radius: var(--radius);
    transition: var(--transition);
    text-align: center;
  }

  .contact__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(44, 36, 32, 0.08);
  }

  .contact__card svg {
    color: var(--accent);
  }

  .contact__label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
  }

  .contact__value {
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  .contact__commissions {
    border-top: 1px solid var(--divider);
    padding-top: var(--space-xl);
  }

  .contact__subheading {
    font-size: 1.5rem;
    margin-bottom: var(--space-md);
    font-weight: 400;
  }

  .contact__commissions p {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .contact__commissions strong {
    color: var(--accent);
  }
</style>
